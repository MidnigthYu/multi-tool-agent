# ============================================================
# 多工具智能助理 - 环境变量模板
# 使用方式: cp .env.example .env 并填写真实值
# ============================================================
# ---- 推理模型配置 ----
LLM_DEEPSEEK_API_KEY=your-deepseek-api-key-here
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DOUBAO_API_KEY=your-doubao-api-key-here
LLM_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_DOUBAO_MODEL=doubao-pro-128k
# ---- 联网搜索 ----
TAVILY_API_KEY=your-tavily-api-key-here
# ---- 日志配置 ----
LOG_LEVEL=INFO
LOG_FILE=
# ---- 持久化存储路径 ----
CHROMA_PERSIST_DIR=data/chroma_data
SQLITE_DB_PATH=data/sessions.db
UPLOAD_DIR=data/uploads
# ---- 模型与推理阈值 ----
MODEL_REQUEST_TIMEOUT_S=60
MODEL_FALLBACK_COOLDOWN_S=300
FALLBACK_MAX_RETRIES=2
TOKEN_MAX_PER_SESSION=50000
TOKEN_COMPRESS_THRESHOLD=30000
MAX_REFLECTION_ROUNDS=2
# ---- 搜索工具阈值 ----
SEARCH_TIMEOUT_S=15
SEARCH_RETRY_MAX=2
SEARCH_RETRY_BASE_DELAY_S=1
SEARCH_RESULT_MAX_LENGTH=5000
# ---- 文档解析阈值 ----
DOC_MAX_FILE_SIZE_MB=50
DOC_CHUNK_SIZE=1000
DOC_CHUNK_OVERLAP=200
DOC_SUPPORTED_FORMATS=.pdf,.docx,.xlsx
# ---- ChromaDB 存储阈值 ----
CHROMA_HEARTBEAT_INTERVAL_S=30
CHROMA_DEGRADED_THRESHOLD=3
CHROMA_COLLECTION_DOCS=user_docs
CHROMA_COLLECTION_MEMORY=user_memories
# ---- SQLite 存储阈值 ----
SQLITE_BUSY_TIMEOUT_S=5
# ---- 会话阈值 ----
SESSION_EXPIRE_HOURS=24
MID_TERM_SUMMARY_THRESHOLD=20
SHORT_TERM_MAX_MESSAGES=5
SESSION_MAX_ROUNDS=20
# ---- 长期记忆阈值 ----
LONG_TERM_MEMORY_TOP_K=5
LONG_TERM_MEMORY_SIMILARITY_THRESHOLD=0.7
# ---- 代码沙箱阈值 ----
CODE_SANDBOX_TIMEOUT_S=30
CODE_SANDBOX_SOFT_TIMEOUT_S=20
CODE_SANDBOX_MEMORY_LIMIT_MB=512
CODE_SANDBOX_MAX_OUTPUT_CHARS=10000
# ---- Embedding 配置 ----
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536
# ---- WebSocket 配置 ----
WS_HEARTBEAT_INTERVAL_S=30
WS_MAX_CONNECTIONS=100
# ---- CORS 配置 ----
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE
# ---- 限流配置 ----
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_S=60
# ---- 重试与延迟配置 ----
RETRY_BASE_DELAY_S=1
RETRY_MAX_DELAY_S=60
RETRY_JITTER=0.1
# ---- 健康检查配置 ----
HEALTH_CHECK_INTERVAL_S=60
HEALTH_CHECK_TIMEOUT_S=10
